---
import WhatsappIcon from './WhatsappIcon.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';

const phoneHref = `tel:${site.phone.replace(/-/g, '')}`;
const emailHref = `mailto:${site.email}?subject=${encodeURIComponent('פנייה מהאתר')}`;
const whatsappHref = site.whatsapp || phoneHref;
---
<div class="contact-actions-panel card">
  <div>
    <div class="eyebrow">יצירת קשר מהירה</div>
    <h2>בחרו את הדרך שנוחה לכם להתחיל בה</h2>
    <p class="contact-lead">אפשר להתקשר, לשלוח הודעת WhatsApp או לפנות במייל. כל פנייה מתקבלת בדיסקרטיות, ברגישות ובמענה אישי.</p>
    <p class="response-note">בדרך כלל אפשר להתחיל בשאלה קצרה, להבין את הכיוון, ורק אחר כך להחליט איך נכון להמשיך.</p>
  </div>
  <div class="contact-actions-grid">
    <a class="action-card action-whatsapp" href={whatsappHref} target="_blank" rel="noreferrer">
      <WhatsappIcon size={48} />
      <span>WhatsApp Business</span>
      <strong>שליחת הודעה</strong>
    </a>
    <a class="action-card" href={phoneHref}>
      <span class="action-icon"><Icon name="phone" size={24} /></span>
      <span>טלפון</span>
      <strong>{site.phone}</strong>
    </a>
    <a class="action-card" href={emailHref}>
      <span class="action-icon"><Icon name="mail" size={24} /></span>
      <span>אימייל</span>
      <strong>{site.email}</strong>
    </a>
  </div>
</div>

<style>
  .contact-actions-panel {
    display: grid;
    gap: 1.75rem;
    background: linear-gradient(135deg, var(--color-card-strong) 0%, var(--color-surface-warm) 100%);
  }

  .contact-actions-panel h2 {
    font-size: clamp(1.8rem, 2.5vw, 2.45rem);
    margin-bottom: 0.75rem;
  }

  .contact-lead {
    font-size: 1.12rem;
    line-height: 1.95;
    color: var(--color-soft-text);
  }

  .contact-actions-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .action-card {
    min-height: 190px;
    padding: 1.5rem;
    border-radius: 20px;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    display: grid;
    align-content: center;
    justify-items: center;
    text-align: center;
    gap: 0.55rem;
    transition: 180ms ease;
  }

  .action-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-strong);
  }

  .action-card span {
    color: var(--color-muted);
    font-size: 1rem;
  }

  .action-card strong {
    color: var(--color-text);
    font-size: 1.28rem;
    line-height: 1.4;
  }

  .response-note {
    color: var(--color-muted);
    margin-bottom: 0;
    font-size: 1.02rem;
  }

  .action-whatsapp {
    border-color: rgba(37, 211, 102, 0.35);
    background: linear-gradient(135deg, rgba(37, 211, 102, 0.14), var(--color-card-strong));
  }

  .action-icon {
    width: 54px;
    height: 54px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    background: var(--color-pill-bg);
    color: var(--color-primary-deep);
  }

  @media (max-width: 900px) {
    .contact-actions-grid {
      grid-template-columns: 1fr;
    }

    .action-card {
      min-height: 150px;
      padding: 1.15rem;
    }

    .contact-actions-panel {
      gap: 1.1rem;
    }

    .contact-actions-panel h2 {
      margin-bottom: 0.5rem;
    }
  }
</style>
