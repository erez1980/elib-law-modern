---
---
<div class="accessibility-widget" data-accessibility-widget>
  <button class="accessibility-toggle" type="button" aria-label="פתיחת אפשרויות נגישות" aria-expanded="false" data-accessibility-toggle>
    <span aria-hidden="true">♿</span>
  </button>

  <section class="accessibility-panel" aria-label="אפשרויות נגישות" data-accessibility-panel hidden>
    <div class="accessibility-panel-head">
      <strong>אפשרויות נגישות</strong>
      <button type="button" aria-label="סגירת אפשרויות נגישות" data-accessibility-close>×</button>
    </div>

    <div class="accessibility-controls">
      <button type="button" data-a11y-action="font-plus">הגדלת טקסט</button>
      <button type="button" data-a11y-action="font-minus">הקטנת טקסט</button>
      <button type="button" data-a11y-action="contrast">ניגודיות גבוהה</button>
      <button type="button" data-a11y-action="links">הדגשת קישורים</button>
      <button type="button" data-a11y-action="readable-font">גופן קריא</button>
      <button type="button" data-a11y-action="motion">עצירת אנימציות</button>
      <button type="button" data-a11y-action="reset" class="reset">איפוס</button>
    </div>
  </section>
</div>

<script is:inline>
  (() => {
    const key = 'elib-a11y';
    const root = document.documentElement;
    const widget = document.querySelector('[data-accessibility-widget]');
    const toggle = document.querySelector('[data-accessibility-toggle]');
    const panel = document.querySelector('[data-accessibility-panel]');
    const close = document.querySelector('[data-accessibility-close]');
    if (!widget || !toggle || !panel) return;

    const defaults = { fontScale: 0, contrast: false, links: false, readableFont: false, motion: false };
    const load = () => {
      try { return { ...defaults, ...JSON.parse(localStorage.getItem(key) || '{}') }; }
      catch { return { ...defaults }; }
    };
    let state = load();
    const save = () => localStorage.setItem(key, JSON.stringify(state));
    const apply = () => {
      root.dataset.a11yFont = String(state.fontScale);
      root.toggleAttribute('data-a11y-contrast', !!state.contrast);
      root.toggleAttribute('data-a11y-links', !!state.links);
      root.toggleAttribute('data-a11y-readable-font', !!state.readableFont);
      root.toggleAttribute('data-a11y-reduce-motion', !!state.motion);
    };
    const setPanel = (open) => {
      panel.hidden = !open;
      toggle.setAttribute('aria-expanded', String(open));
    };
    toggle.addEventListener('click', () => setPanel(panel.hidden));
    close?.addEventListener('click', () => setPanel(false));
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape') setPanel(false); });
    widget.addEventListener('click', (event) => {
      const target = event.target.closest('[data-a11y-action]');
      if (!target) return;
      const action = target.getAttribute('data-a11y-action');
      if (action === 'font-plus') state.fontScale = Math.min(3, state.fontScale + 1);
      if (action === 'font-minus') state.fontScale = Math.max(0, state.fontScale - 1);
      if (action === 'contrast') state.contrast = !state.contrast;
      if (action === 'links') state.links = !state.links;
      if (action === 'readable-font') state.readableFont = !state.readableFont;
      if (action === 'motion') state.motion = !state.motion;
      if (action === 'reset') state = { ...defaults };
      save();
      apply();
    });
    apply();
  })();
</script>

<style is:global>
  :root[data-a11y-font='1'] { font-size: 17px; }
  :root[data-a11y-font='2'] { font-size: 18px; }
  :root[data-a11y-font='3'] { font-size: 19px; }
  :root[data-a11y-readable-font] body,
  :root[data-a11y-readable-font] button,
  :root[data-a11y-readable-font] input,
  :root[data-a11y-readable-font] textarea { font-family: Arial, Helvetica, sans-serif !important; }
  :root[data-a11y-links] a { text-decoration: underline !important; text-underline-offset: 0.18em; text-decoration-thickness: 2px; }
  :root[data-a11y-reduce-motion] *,
  :root[data-a11y-reduce-motion] *::before,
  :root[data-a11y-reduce-motion] *::after { animation: none !important; transition: none !important; scroll-behavior: auto !important; }
  :root[data-a11y-contrast] {
    --color-primary: #ffd24a; --color-primary-deep: #ffd24a; --color-text: #ffffff; --color-muted: #ffffff;
    --color-surface: #000000; --color-surface-warm: #000000; --color-border: #ffffff; --color-white: #000000;
    --color-page-top: #000000; --color-header: rgba(0, 0, 0, 0.96); --color-header-border: #ffffff;
    --color-card: #000000; --color-card-strong: #000000; --color-overlay: #000000; --color-overlay-text: #ffffff;
    --color-pill-bg: #000000; --color-pill-text: #ffd24a; --color-soft-text: #ffffff; --color-footer-bg-start: #000000;
    --color-footer-bg-end: #000000; --shadow-soft: none; --shadow-strong: none;
  }
  :focus-visible { outline: 3px solid var(--color-primary) !important; outline-offset: 4px; }
</style>

<style>
  .accessibility-widget {
    position: fixed;
    right: 1rem;
    bottom: 7rem;
    z-index: 45;
    direction: rtl;
  }
  .accessibility-toggle {
    width: 44px; height: 44px; border-radius: 14px; border: 1px solid var(--color-border);
    background: var(--color-card-strong); color: var(--color-text); font-size: 1.05rem; font-weight: 800;
    display: grid; place-items: center; box-shadow: var(--shadow-soft); cursor: pointer;
  }
  .accessibility-panel {
    position: absolute; right: 0; bottom: calc(100% + 0.75rem); width: min(310px, calc(100vw - 2rem));
    padding: 1rem; border-radius: 18px; border: 1px solid var(--color-border); background: var(--color-card-strong);
    box-shadow: var(--shadow-strong); color: var(--color-text);
  }
  .accessibility-panel-head {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 0.85rem;
  }
  .accessibility-panel-head button {
    width: 34px; height: 34px; border-radius: 999px; border: 1px solid var(--color-border); background: var(--color-card);
    color: var(--color-text); cursor: pointer; font-size: 1.25rem;
  }
  .accessibility-controls { display: grid; grid-template-columns: 1fr; gap: 0.55rem; }
  .accessibility-controls button {
    min-height: 42px; border-radius: 12px; border: 1px solid var(--color-border); background: var(--color-card);
    color: var(--color-text); font-weight: 700; cursor: pointer; text-align: right; padding: 0.65rem 0.8rem;
  }
  .accessibility-controls .reset { color: var(--color-primary-deep); }
  @media (max-width: 900px) {
    .accessibility-widget { right: 0.75rem; bottom: 5.9rem; }
    .accessibility-toggle { width: 38px; height: 38px; font-size: 0.95rem; border-radius: 12px; }
    .accessibility-panel { width: min(285px, calc(100vw - 1.5rem)); padding: 0.85rem; }
  }
</style>
