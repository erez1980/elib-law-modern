---
import { site } from '../data/site';

const endpoint = `https://formsubmit.co/${site.email}`;
const whatsappHref = site.whatsapp || '';
---
<form class="card form-grid" action={endpoint} method="POST">
  <input type="hidden" name="_subject" value="פנייה חדשה מהאתר" />
  <input type="hidden" name="_captcha" value="false" />
  <input type="hidden" name="_template" value="table" />
  <input type="hidden" name="_next" value={`${site.domain}/thank-you`} />
  <label>
    שם מלא
    <input type="text" name="name" placeholder="איך נוכל לפנות אליך?" required />
  </label>
  <label>
    טלפון
    <input type="tel" name="phone" placeholder="050-0000000" required />
  </label>
  <label>
    אימייל
    <input type="email" name="email" placeholder={site.email} />
  </label>
  <label>
    נושא
    <input type="text" name="subject" placeholder="בקצרה על מה מדובר" />
  </label>
  <label class="full">
    הודעה
    <textarea name="message" rows="6" placeholder="אפשר לכתוב כאן כמה מילים, ואחזור בהקדם."></textarea>
  </label>
  <div class="form-actions full">
    <button class="button button-primary" type="submit">שליחת פנייה</button>
    {whatsappHref ? (
      <a class="button button-secondary" href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
    ) : (
      <span class="whatsapp-note">קישור WhatsApp יתווסף ברגע שתשלח אותו.</span>
    )}
  </div>
</form>

<style>
  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  label {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    min-height: 52px;
    padding: 0.9rem 1rem;
    font: inherit;
    background: white;
  }

  textarea {
    min-height: 180px;
    resize: vertical;
  }

  .full {
    grid-column: 1 / -1;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .whatsapp-note {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
