---
import WhatsappIcon from './WhatsappIcon.astro';
import { site } from '../data/site';

const phoneHref = `tel:${site.phone.replace(/-/g, '')}`;
const whatsappHref = site.whatsapp || phoneHref;
---
<div class="floating-actions">
  <a href={phoneHref} class="floating-chip">שיחה</a>
  <a href={whatsappHref} class="floating-chip floating-chip--whatsapp" target={site.whatsapp ? '_blank' : undefined} rel={site.whatsapp ? 'noreferrer' : undefined} aria-label="שליחת הודעת WhatsApp">
    <WhatsappIcon size={22} />
    <span>WhatsApp</span>
  </a>
</div>

<style>
  .floating-actions {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 30;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .floating-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-width: 112px;
    min-height: 48px;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    background: #1f1f1f;
    color: #ffffff;
    box-shadow: 0 16px 40px rgba(31, 31, 31, 0.18);
    font-weight: 700;
    backdrop-filter: blur(10px);
  }

  .floating-chip--whatsapp {
    background: var(--color-card-strong);
    color: #128c4a;
    border: 1px solid rgba(37, 211, 102, 0.35);
  }

  :root[data-theme='dark'] .floating-chip:not(.floating-chip--whatsapp) {
    background: var(--color-card-strong);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .floating-chip:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .floating-actions {
      left: 0.75rem;
      right: 0.75rem;
      bottom: 0.75rem;
      flex-direction: row;
    }

    .floating-chip {
      flex: 1;
      min-width: 0;
      min-height: 52px;
    }
  }
</style>
