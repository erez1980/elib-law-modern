---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import { contactCards, site } from '../data/site';
import contactPage from '../data/contact-page.json';
---
<BaseLayout title="צור קשר | עו״ד אליזבט ברזאני דדון">
  <section class="section contact-shell">
    <div class="container contact-grid">
      <div class="contact-content">
        <SectionHeading eyebrow="צור קשר" title={contactPage.title} description={contactPage.description} />
        <div class="grid cards-grid">
          {contactCards.map((item) => (
            <a class="card contact-card" href={item.href}>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </a>
          ))}
        </div>
        <div class="card hours-card">
          <h3>שעות פעילות</h3>
          <ul>
            {site.hours.map((item) => <li>{item}</li>)}
          </ul>
          <p class="small-note">{contactPage.formSuccessNote}</p>
        </div>
      </div>
      <ContactForm />
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid,
  .cards-grid {
    display: grid;
    gap: 1.5rem;
  }

  .contact-grid {
    grid-template-columns: 0.9fr 1.1fr;
    align-items: start;
  }

  .cards-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: 1.5rem;
  }

  .contact-card {
    display: grid;
    gap: 0.45rem;
    min-height: 100%;
    background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
  }

  .contact-card span {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .contact-card strong {
    color: var(--color-text);
    word-break: break-word;
  }

  .hours-card ul {
    margin: 0;
    padding-right: 1rem;
  }

  .small-note {
    margin-top: 1rem;
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .contact-grid,
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
