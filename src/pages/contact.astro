---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactActions from '../components/ContactActions.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
import contactPage from '../data/contact-page.json';
---
<BaseLayout title="צור קשר | עו״ד אליזבט ברזאני דדון">
  <PageHero eyebrow="צור קשר" title={contactPage.title} description={contactPage.description} />

  <section class="section contact-shell">
    <div class="container contact-layout">
      <ContactActions />
      <div class="card hours-card">
        <h3>שעות פעילות</h3>
        <ul>
          {site.hours.map((item) => <li>{item}</li>)}
        </ul>
        <h3>כתובת</h3>
        <p>{site.address}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-shell {
    padding-top: 1.5rem;
  }

  .contact-layout {
    display: grid;
    gap: 1.5rem;
    max-width: 900px;
  }

  .hours-card h3 {
    margin-bottom: 0.35rem;
  }

  .hours-card p,
  .hours-card li {
    color: #5a5a5a;
  }

  .hours-card {
    display: grid;
    gap: 0.75rem;
  }

  .hours-card ul {
    margin: 0;
    padding-right: 1rem;
  }
</style>
