---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactActions from '../components/ContactActions.astro';
import ContactForm from '../components/ContactForm.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
import contactPage from '../data/contact-page.json';
---
<BaseLayout title="צור קשר | עו״ד אליזבט ברזאני דדון">
  <PageHero eyebrow="צור קשר" title={contactPage.title} description={contactPage.description} />

  <section class="section contact-shell">
    <div class="container contact-layout">
      <ContactActions />
      <ContactForm />
      <div class="card hours-card">
        <h3>שעות פעילות</h3>
        <ul>
          {site.hours.map((item) => <li>{item}</li>)}
        </ul>
        <h3>כתובת</h3>
        <p>{site.address}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-shell {
    padding-top: 1.5rem;
  }

  .contact-layout {
    display: grid;
    gap: 1.5rem;
    max-width: 1040px;
  }

  .hours-card h3 {
    margin-bottom: 0.35rem;
    font-size: 1.3rem;
  }

  .hours-card p,
  .hours-card li {
    color: var(--color-soft-text);
    font-size: 1.02rem;
    line-height: 1.9;
  }

  .hours-card {
    display: grid;
    gap: 0.75rem;
    background: linear-gradient(180deg, var(--color-card-strong) 0%, var(--color-surface-warm) 100%);
  }

  .hours-card ul {
    margin: 0;
    padding-right: 1rem;
  }

  @media (max-width: 900px) {
    .contact-shell {
      padding-top: 0.8rem;
    }

    .contact-layout {
      gap: 1rem;
    }

    .hours-card {
      gap: 0.55rem;
    }
  }
</style>
