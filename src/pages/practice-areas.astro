---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection, render } from 'astro:content';

const practiceAreas = (await getCollection('practiceAreas')).sort((a, b) => a.data.order - b.data.order);
const renderedAreas = await Promise.all(
  practiceAreas.map(async (area) => ({
    area,
    rendered: await render(area),
  })),
);
---
<BaseLayout title="תחומי עיסוק | עו״ד אליזבט ברזאני דדון">
  <section class="section">
    <div class="container areas-shell">
      <SectionHeading eyebrow="תחומי עיסוק" title="תחומים משפטיים שבהם המשרד מלווה באופן אישי, רגיש ומדויק" description="העמוד הזה נבנה מחדש עם היררכיה הרבה יותר נקייה: פחות עומס, יותר בהירות, ויכולת להתרחב בהמשך לעמודי SEO ייעודיים לכל תחום." />
      <div class="areas-grid">
        {renderedAreas.map(({ area, rendered }) => {
          const { Content } = rendered;
          return (
            <article class="card area-card">
              <div class="area-head">
                <h2>{area.data.title}</h2>
                <p>{area.data.summary}</p>
              </div>
              <div class="content"><Content /></div>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .areas-shell,
  .areas-grid {
    display: grid;
    gap: 1.5rem;
  }

  .areas-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .area-card {
    min-height: 100%;
    display: grid;
    gap: 1rem;
  }

  .area-head {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(230, 230, 230, 0.9);
  }

  .content :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .areas-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
