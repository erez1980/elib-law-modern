---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection, render } from 'astro:content';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const seoServiceMap: Record<string, string> = {
  'גירושין': '/services/divorce-lawyer',
  'מזונות': '/services/child-support-lawyer',
  'משמורת והסדרי שהות': '/services/custody-lawyer',
  'צוואות וירושות': '/services/will-lawyer',
  'ייפוי כוח מתמשך': '/services/lasting-power-attorney-lawyer',
  'גישור משפחתי': '/services/family-mediation',
};
const practiceAreas = (await getCollection('practiceAreas')).sort((a, b) => a.data.order - b.data.order);
const renderedAreas = await Promise.all(
  practiceAreas.map(async (area) => ({
    area,
    rendered: await render(area),
  })),
);
---
<BaseLayout title="תחומי עיסוק | עו״ד אליזבט ברזאני דדון">
  <section class="section">
    <div class="container areas-shell">
      <SectionHeading eyebrow="תחומי עיסוק" title="תחומים משפטיים שבהם המשרד מלווה באופן אישי, רגיש ומדויק" description="שירות משפטי וגישורי בענייני משפחה, עם מיקוד בפתרונות מעשיים, הסכמות כשאפשר וייצוג נחוש כשצריך." />
      <div class="areas-grid">
        {renderedAreas.map(({ area, rendered }) => {
          const { Content } = rendered;
          return (
            <article class="card area-card">
              <div class="area-head">
                <h2>{area.data.title}</h2>
                <p>{area.data.summary}</p>
              </div>
              <div class="content"><Content /></div>
              {seoServiceMap[area.data.title] && (
                <a class="text-link" href={withBase(seoServiceMap[area.data.title])}>למידע נוסף על התחום</a>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .areas-shell,
  .areas-grid {
    display: grid;
    gap: 1.5rem;
  }

  .areas-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .area-card {
    min-height: 100%;
    display: grid;
    gap: 1rem;
  }

  .area-head {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(230, 230, 230, 0.9);
  }

  .content :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .areas-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
