---
import BaseLayout from '../layouts/BaseLayout.astro';
const homeHref = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---
<BaseLayout title="העמוד לא נמצא | עו״ד אליזבט ברזאני דדון">
  <section class="section">
    <div class="container card" style="max-width: 720px; text-align: center;">
      <div class="eyebrow">404</div>
      <h1>העמוד שחיפשת לא נמצא</h1>
      <p>אפשר לחזור לדף הבית או ליצור קשר ולקבל מענה אישי.</p>
      <a href={homeHref} class="button button-primary">לדף הבית</a>
    </div>
  </section>
</BaseLayout>
