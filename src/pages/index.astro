---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PracticeAreasPreview from '../components/PracticeAreasPreview.astro';
import FaqPreview from '../components/FaqPreview.astro';
import { highlights, site } from '../data/site';
import { homePage } from '../data/home';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const heroImage = withBase(site.heroImage);
const trustBadges = [
  'חברת לשכת עורכי הדין משנת 2008',
  'ליווי אישי וישיר בכל תיק',
  'גישה משפטית וגישורית לפי מה שנכון למקרה',
];
const credibilityPoints = [
  'עו״ד ומגשרת לדיני משפחה',
  'טיפול ישיר ללא מתמחים',
  'רגישות, דיסקרטיות ושיקול דעת',
];
const featuredServices = [
  { title: 'גירושין', text: 'ליווי משפטי מדויק בתחילת הדרך, במו״מ, בגישור או בהליך משפטי.', href: '/services/divorce-lawyer' },
  { title: 'מזונות ומשמורת', text: 'בניית מסגרת ברורה ויציבה לילדים ולהורים, עם ראייה מעשית ואנושית.', href: '/services/custody-lawyer' },
  { title: 'צוואות וירושות', text: 'עריכת צוואות, ליווי בירושות וטיפול במחלוקות משפחתיות רגישות.', href: '/services/will-lawyer' },
  { title: 'ייפוי כוח מתמשך', text: 'תכנון משפטי אחראי שנותן שקט נפשי לעתיד.', href: '/services/lasting-power-attorney-lawyer' },
];
---
<BaseLayout>
  <section class="section hero-shell">
    <div class="container hero-grid">
      <div class="hero-main">
        <div class="eyebrow">{homePage.hero.kicker}</div>
        <h1>{homePage.hero.title}</h1>
        <p class="hero-copy">{homePage.hero.description}</p>

        <div class="hero-actions">
          <a class="button button-primary" href={withBase(homePage.hero.primaryCta.href)}>{homePage.hero.primaryCta.label}</a>
          <a class="button button-secondary" href={withBase(homePage.hero.secondaryCta.href)}>{homePage.hero.secondaryCta.label}</a>
        </div>

        <ul class="hero-meta">
          {trustBadges.map((badge) => <li>{badge}</li>)}
        </ul>
      </div>

      <aside class="hero-stack">
        <div class="hero-image-card card">
          <img src={heroImage} alt={site.shortName} />
          <div class="hero-image-overlay">
            <strong>ליווי מקצועי, אישי ודיסקרטי</strong>
            <span>במצבים שבהם צריך גם בהירות משפטית וגם יד יציבה ורגישה</span>
          </div>
        </div>

        <div class="hero-credibility card">
          {credibilityPoints.map((point) => (
            <div class="credibility-row">
              <span>{point}</span>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section trust-strip">
    <div class="container trust-band card">
      <div class="trust-copy">
        <div class="eyebrow">אמון, בהירות וגישה אנושית</div>
        <h2>משרד שמחבר בין הבנה אנושית עמוקה לבין עבודה משפטית שקולה ומדויקת</h2>
        <p>לא כל מקרה צריך עימות. לא כל הסכמה היא הסכמה נכונה. המטרה היא להבין מה ישרת אותך באמת - ולבנות משם דרך פעולה נכונה.</p>
      </div>
      <div class="trust-proof-list">
        <div class="trust-proof-item"><strong>2008+</strong><span>שנות ניסיון מקצועי</span></div>
        <div class="trust-proof-item"><strong>גישור + משפט</strong><span>בחירת הדרך המתאימה לכל מקרה</span></div>
        <div class="trust-proof-item"><strong>יחס אישי</strong><span>טיפול ישיר, רגיש ודיסקרטי</span></div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <SectionHeading eyebrow="למה לבחור במשרד" title="ליווי שמוריד עומס, מייצר בהירות, ועוזר לקבל החלטות טובות יותר" description={homePage.intro} />
      <div class="grid highlight-grid">
        {highlights.map((item) => (
          <article class="card highlight-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-section">
      <div class="story-card card">
        <SectionHeading eyebrow="אודות המשרד" title="עורכת דין ומגשרת שמלווה ברגישות, בנוכחות, ובחשיבה לטווח ארוך" description="כשיש מתח, בלבול או חוסר ודאות, חשוב לעבוד עם מי שיודעת גם להחזיק את הסיטואציה האנושית וגם להוביל את המהלך המשפטי בצורה מדויקת." />
        <p>
          עו״ד ומגשרת אליזבט ברזאני דדון מלווה לקוחות בענייני גירושין, גישור משפחתי, משמורת, מזונות, חלוקת רכוש,
          צוואות, ירושות, ייפוי כוח מתמשך והסכמים - מתוך הקשבה אמיתית, סדר מחשבתי וראייה רחבה של התמונה כולה.
        </p>
        <p>
          הליווי נעשה באופן אישי וישיר, עם מטרה כפולה: גם להגן על האינטרסים המשפטיים שלך, וגם להפחית ככל האפשר רעש,
          בלבול ועומס בתקופה שהיא ממילא רגישה ומורכבת.
        </p>
      </div>
      <div class="card warmth-card">
        <div class="eyebrow">איך זה מרגיש בפועל</div>
        <ul class="warmth-list">
          <li>שיחה ברורה, בלי מילים משפטיות שמעמיסות סתם</li>
          <li>בחינה אמיתית של האפשרויות, לא תגובה אוטומטית</li>
          <li>רגישות כשאפשר, ונחישות כשצריך</li>
          <li>תחושת סדר ובהירות כבר מהשלבים הראשונים</li>
        </ul>
        <a class="text-link" href={withBase('/about')}>לקריאה נוספת על המשרד</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container areas-shell">
      <SectionHeading eyebrow="תחומי עיסוק" title="התחומים המרכזיים שבהם המשרד מלווה באופן אישי ומדויק" description="במקום להעמיס בדף הבית את כל שכבות התוכן, ריכזנו כאן את הנושאים המרכזיים שמעסיקים לקוחות בתחילת הדרך." />
      <div class="service-links-grid">
        {featuredServices.map((service) => (
          <a class="card service-link-card" href={withBase(service.href)}>
            <strong>{service.title}</strong>
            <span>{service.text}</span>
          </a>
        ))}
      </div>
      <div class="areas-footer-link">
        <a class="button button-secondary" href={withBase('/practice-areas')}>לכל תחומי העיסוק</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container process-shell">
      <div class="process-intro">
        <SectionHeading eyebrow="תהליך העבודה" title="כך נראה תהליך נכון, מסודר ורגוע יותר" description="הצעד הראשון הוא לא לרוץ - אלא להבין. משם אפשר לבחור דרך פעולה מדויקת יותר, עם פחות טעויות ויותר שקט." />
      </div>
      <div class="grid process-cards">
        {homePage.process.map((step, index) => (
          <article class="card process-card">
            <span class="step-index">0{index + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container faq-shell">
      <SectionHeading eyebrow="שאלות נפוצות" title="שאלות שאנשים שואלים כשהם רוצים להבין מה נכון לעשות עכשיו" description="תשובות ראשוניות, קצרות וברורות, בנושאים שעולים הרבה בתחילת הדרך - לפני פגישה, לפני החלטה, ולפני צעד משפטי." />
      <FaqPreview />
    </div>
  </section>

  <section class="section">
    <div class="container cta-banner card">
      <div>
        <div class="eyebrow">יצירת קשר</div>
        <h2>{homePage.cta.title}</h2>
        <p>{homePage.cta.text}</p>
      </div>
      <div class="hero-actions cta-actions">
        <a class="button button-primary" href={withBase(homePage.cta.primary.href)}>{homePage.cta.primary.label}</a>
        <a class="button button-secondary" href={withBase(homePage.cta.secondary.href)}>{homePage.cta.secondary.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-shell {
    padding-top: 2.5rem;
  }

  .hero-grid,
  .split-section,
  .process-shell {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: 2rem;
    align-items: start;
  }

  .hero-main {
    padding-top: 1rem;
  }

  .hero-copy {
    font-size: 1.08rem;
    line-height: 1.95;
    max-width: 58ch;
    color: var(--color-soft-text);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 1.75rem 0;
  }

  .hero-meta {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.9rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .hero-meta li {
    position: relative;
    padding-right: 1.2rem;
  }

  .hero-meta li::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    position: absolute;
    right: 0;
    top: 0.65rem;
  }

  .hero-stack {
    display: grid;
    gap: 1rem;
  }

  .hero-image-card {
    position: relative;
    overflow: hidden;
    padding: 0.85rem;
    border-radius: 28px;
    background: linear-gradient(135deg, var(--color-pill-bg) 0%, var(--color-card-strong) 100%);
  }

  .hero-image-card:hover,
  .highlight-card:hover,
  .service-link-card:hover,
  .process-card:hover,
  .warmth-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-strong);
    border-color: rgba(255, 182, 55, 0.28);
  }

  .hero-image-card img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 22px;
  }

  .hero-image-overlay {
    position: absolute;
    right: 1.5rem;
    left: 1.5rem;
    bottom: 1.5rem;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: var(--color-overlay);
    color: var(--color-text);
    display: grid;
    gap: 0.35rem;
  }

  .hero-image-overlay span {
    color: var(--color-overlay-text);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .hero-credibility {
    display: grid;
    gap: 0.75rem;
    background: linear-gradient(180deg, var(--color-card) 0%, var(--color-surface-warm) 100%);
  }

  .hero-credibility span,
  .credibility-row {
    color: var(--color-text);
  }

  .credibility-row {
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgba(230, 230, 230, 0.9);
    font-weight: 700;
    color: #555;
  }

  .credibility-row:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .trust-strip {
    padding-top: 1rem;
  }

  .trust-band {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: center;
    background: linear-gradient(120deg, var(--color-card-strong) 0%, var(--color-surface-warm) 100%);
  }

  .trust-copy p {
    margin-bottom: 0;
  }

  .trust-proof-list,
  .highlight-grid,
  .process-cards,
  .service-links-grid {
    display: grid;
    gap: 1rem;
  }

  .trust-proof-item {
    padding: 1rem 1.1rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 182, 55, 0.24);
    background: var(--color-card);
    display: grid;
    gap: 0.25rem;
  }

  .trust-proof-item strong {
    font-size: 1.05rem;
  }

  .trust-proof-item span {
    color: var(--color-muted);
  }

  .highlight-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .highlight-card,
  .story-card,
  .warmth-card,
  .process-card,
  .cta-banner {
    min-height: 100%;
  }

  .story-card {
    background: linear-gradient(180deg, var(--color-card-strong) 0%, var(--color-surface-warm) 100%);
  }

  .warmth-card {
    background: linear-gradient(180deg, var(--color-card-strong) 0%, var(--color-surface-warm) 100%);
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .warmth-list {
    margin: 0;
    padding-right: 1.2rem;
    display: grid;
    gap: 0.7rem;
    color: var(--color-soft-text);
  }

  .story-card p,
  .highlight-card p,
  .process-card p,
  .cta-banner p,
  .warmth-card p {
    color: var(--color-soft-text);
    line-height: 1.9;
  }

  .areas-shell,
  .faq-shell {
    display: grid;
    gap: 1.5rem;
  }

  .service-links-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .service-link-card {
    display: grid;
    gap: 0.45rem;
    background: linear-gradient(180deg, var(--color-card) 0%, var(--color-surface-warm) 100%);
  }

  .service-link-card span {
    color: var(--color-muted);
  }

  .areas-footer-link {
    display: flex;
    justify-content: center;
  }

  .process-shell {
    grid-template-columns: 0.92fr 1.08fr;
  }

  .process-cards {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .step-index {
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-pill-bg);
    border: 1px solid rgba(255, 182, 55, 0.35);
    color: var(--color-pill-text);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .cta-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: linear-gradient(120deg, #1f1f1f 0%, #2b2b2b 100%);
    color: white;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: 0 24px 70px rgba(31,31,31,0.2);
  }

  .cta-banner p,
  .cta-banner h2 {
    color: white;
  }

  .cta-banner .eyebrow {
    color: var(--color-pill-text);
    background: rgba(255, 182, 55, 0.18);
  }

  .cta-banner .button-secondary {
    color: white;
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.08);
  }

  .cta-actions {
    margin: 0;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .split-section,
    .process-shell,
    .trust-band,
    .highlight-grid,
    .process-cards,
    .service-links-grid,
    .cta-banner {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: stretch;
    }

    .hero-shell {
      padding-top: 1.05rem;
    }

    .hero-main {
      padding-top: 0;
    }

    .hero-actions {
      margin: 0.9rem 0 1rem;
      gap: 0.75rem;
    }

    .hero-actions .button {
      width: 100%;
    }

    .hero-image-card img {
      aspect-ratio: 16 / 12;
    }

    .hero-image-overlay {
      position: static;
      margin-top: 0.65rem;
      padding: 0.85rem 0.9rem;
      background: var(--color-overlay);
    }

    .hero-meta {
      gap: 0.7rem;
    }

    .hero-meta li {
      padding-right: 1rem;
    }

    .trust-strip {
      padding-top: 0.4rem;
    }

    .trust-band,
    .areas-shell,
    .faq-shell,
    .process-shell {
      gap: 1rem;
    }

    .trust-proof-item {
      padding: 0.9rem 1rem;
    }

    .trust-proof-list,
    .process-cards,
    .service-links-grid,
    .highlight-grid {
      grid-template-columns: 1fr;
    }

    .warmth-card {
      gap: 0.8rem;
    }

    .cta-banner {
      gap: 1rem;
    }
  }
</style>
