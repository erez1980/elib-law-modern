---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PracticeAreasPreview from '../components/PracticeAreasPreview.astro';
import FaqPreview from '../components/FaqPreview.astro';
import { contactCards, highlights, site } from '../data/site';
import { homePage } from '../data/home';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const heroImage = withBase(site.heroImage);
const trustBadges = [
  'חברת לשכת עורכי הדין משנת 2008',
  'שירות אישי וישיר ללא מתמחים',
  'ליווי דיסקרטי בדיני משפחה, צוואות וייפוי כוח מתמשך',
];
const quickFacts = [
  { title: 'ניסיון מקצועי', value: '2008+' },
  { title: 'תחום התמחות', value: 'דיני משפחה' },
  { title: 'סגנון עבודה', value: 'ליווי אישי' },
];
---
<BaseLayout>
  <section class="section hero-shell">
    <div class="container hero-grid">
      <div class="hero-main">
        <div class="eyebrow">{homePage.hero.kicker}</div>
        <h1>{homePage.hero.title}</h1>
        <p class="hero-copy">{homePage.hero.description}</p>

        <div class="hero-actions">
          <a class="button button-primary" href={withBase(homePage.hero.primaryCta.href)}>{homePage.hero.primaryCta.label}</a>
          <a class="button button-secondary" href={withBase(homePage.hero.secondaryCta.href)}>{homePage.hero.secondaryCta.label}</a>
        </div>

        <ul class="hero-meta">
          {trustBadges.map((badge) => <li>{badge}</li>)}
        </ul>
      </div>

      <aside class="hero-stack">
        <div class="hero-image-card card">
          <img src={heroImage} alt={site.shortName} />
          <div class="hero-image-overlay">
            <strong>ליווי מדויק בתקופות מורכבות</strong>
            <span>שילוב בין רגישות, אסטרטגיה ובהירות משפטית</span>
          </div>
        </div>

        <div class="hero-facts card">
          {quickFacts.map((fact) => (
            <div class="fact-row">
              <span>{fact.title}</span>
              <strong>{fact.value}</strong>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section trust-strip">
    <div class="container trust-band card">
      <div>
        <div class="eyebrow">אמון, בהירות ומקצועיות</div>
        <h2>משרד שנועד לתת לא רק תשובה משפטית נכונה, אלא גם תחושת כיוון ושקט</h2>
      </div>
      <div class="trust-points">
        <span>ליווי אישי</span>
        <span>דיסקרטיות מלאה</span>
        <span>חשיבה אסטרטגית</span>
        <span>שירות בגובה העיניים</span>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <SectionHeading eyebrow="למה לבחור במשרד" title="משרד בוטיק שמחבר בין אנושיות, אסטרטגיה ומשפט" description={homePage.intro} />
      <div class="grid highlight-grid">
        {highlights.map((item) => (
          <article class="card highlight-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-section">
      <div class="story-card card">
        <SectionHeading eyebrow="אודות המשרד" title="ליווי אישי למי שמתמודד עם החלטות משמעותיות ורגישות" description="המשרד משלב ניסיון משפטי עם גישה גישורית, כדי לבחור בכל מקרה את הדרך הנכונה: הידברות, הסכם או ייצוג משפטי נחוש כשצריך." />
        <p>
          עו״ד ומגשרת אליזבט ברזאני דדון מלווה לקוחות בהליכי גירושין, גישור משפחתי, משמורת, מזונות, חלוקת רכוש, צוואות,
          ירושות, ייפוי כוח מתמשך והסכמים - תוך הקפדה על יחס אישי, שקיפות וחשיבה לטווח ארוך.
        </p>
        <p>
          המטרה היא לייצר לא רק שירות משפטי מקצועי, אלא גם חוויה מסודרת, בהירה ומרגיעה ככל האפשר.
        </p>
      </div>
      <div class="card contact-side-card">
        <div class="eyebrow">פרטי קשר</div>
        <div class="contact-mini-grid">
          {contactCards.map((item) => (
            <a class="mini-card" href={item.href}>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container areas-shell">
      <SectionHeading eyebrow="תחומי עיסוק" title="מענה משפטי רחב בתוך התמחות אחת ברורה" description="דיני משפחה דורשים מבט רחב: משפט, רגש, הורות, רכוש ועתיד. לכן כל תחום מוצג כאן בצורה ברורה, נגישה ומכוונת פעולה." />
      <PracticeAreasPreview />
      <div class="service-links-grid">
        <a class="card service-link-card" href={withBase('/services/divorce-lawyer')}><strong>עורך דין גירושין</strong><span>מידע ממוקד על ליווי בהליך גירושין</span></a>
        <a class="card service-link-card" href={withBase('/services/child-support-lawyer')}><strong>עורך דין מזונות</strong><span>הבנת הזכויות והאפשרויות בענייני מזונות</span></a>
        <a class="card service-link-card" href={withBase('/services/custody-lawyer')}><strong>עורך דין משמורת והסדרי שהות</strong><span>הסדרה הורית מתוך ראייה מעשית ורגישה</span></a>
        <a class="card service-link-card" href={withBase('/services/family-mediation')}><strong>גישור משפחתי</strong><span>מתי נכון ללכת להסכמות ואיך עושים זאת נכון</span></a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container process-shell">
      <div class="process-intro">
        <SectionHeading eyebrow="תהליך העבודה" title="שלבים ברורים שמורידים בלבול, עומס ואי ודאות" description="המסר הוא לא רק מה המשרד עושה - אלא איך נראה תהליך נכון, רגוע ומקצועי מהרגע הראשון." />
      </div>
      <div class="grid process-cards">
        {homePage.process.map((step, index) => (
          <article class="card process-card">
            <span class="step-index">0{index + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container faq-shell">
      <SectionHeading eyebrow="שאלות נפוצות" title="שאלות שעולות לפני שמקבלים החלטות חשובות" description="תשובות קצרות וברורות לנושאים שמעסיקים לקוחות בתחילת הדרך: גירושין, גישור, ילדים, רכוש, צוואות וייפוי כוח מתמשך." />
      <FaqPreview />
    </div>
  </section>

  <section class="section">
    <div class="container cta-banner card">
      <div>
        <div class="eyebrow">יצירת קשר</div>
        <h2>{homePage.cta.title}</h2>
        <p>{homePage.cta.text}</p>
      </div>
      <div class="hero-actions cta-actions">
        <a class="button button-primary" href={withBase(homePage.cta.primary.href)}>{homePage.cta.primary.label}</a>
        <a class="button button-secondary" href={withBase(homePage.cta.secondary.href)}>{homePage.cta.secondary.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-shell {
    padding-top: 2.5rem;
  }

  .hero-grid,
  .split-section,
  .process-shell {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: 2rem;
    align-items: start;
  }

  .hero-main {
    padding-top: 1rem;
  }

  .hero-copy {
    font-size: 1.08rem;
    line-height: 1.95;
    max-width: 60ch;
    color: #565656;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 1.75rem 0;
  }

  .hero-meta {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.9rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .hero-meta li {
    position: relative;
    padding-right: 1.2rem;
  }

  .hero-meta li::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    position: absolute;
    right: 0;
    top: 0.65rem;
  }

  .hero-stack {
    display: grid;
    gap: 1rem;
  }

  .hero-image-card {
    position: relative;
    overflow: hidden;
    padding: 0.85rem;
    border-radius: 28px;
    background: linear-gradient(135deg, #fff7e6 0%, #ffffff 100%);
  }

  .hero-image-card img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 22px;
  }

  .hero-image-overlay {
    position: absolute;
    right: 1.5rem;
    left: 1.5rem;
    bottom: 1.5rem;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: rgba(31, 31, 31, 0.78);
    color: white;
    display: grid;
    gap: 0.35rem;
  }

  .hero-image-overlay span {
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .hero-facts {
    display: grid;
    gap: 0.8rem;
  }

  .fact-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(230, 230, 230, 0.9);
  }

  .fact-row:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .fact-row span {
    color: var(--color-muted);
  }

  .fact-row strong {
    font-size: 1.05rem;
  }

  .trust-strip {
    padding-top: 1rem;
  }

  .trust-band {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
    background: linear-gradient(120deg, #fff 0%, #fff8ea 100%);
  }

  .trust-points,
  .highlight-grid,
  .contact-mini-grid,
  .process-cards {
    display: grid;
    gap: 1rem;
  }

  .trust-points {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .trust-points span {
    padding: 0.95rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 182, 55, 0.28);
    background: rgba(255, 255, 255, 0.9);
    font-weight: 700;
    text-align: center;
  }

  .highlight-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .highlight-card,
  .story-card,
  .contact-side-card,
  .process-card,
  .cta-banner {
    min-height: 100%;
  }

  .story-card {
    background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
  }

  .contact-side-card {
    background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  }

  .contact-mini-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .mini-card {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.88);
  }

  .mini-card span {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .story-card p,
  .highlight-card p,
  .process-card p,
  .cta-banner p {
    color: #595959;
    line-height: 1.9;
  }

  .mini-card strong {
    color: var(--color-text);
    word-break: break-word;
  }

  .areas-shell,
  .faq-shell,
  .service-links-grid {
    display: grid;
    gap: 1.5rem;
  }

  .service-links-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .service-link-card {
    display: grid;
    gap: 0.35rem;
  }

  .service-link-card span {
    color: var(--color-muted);
  }

  .process-shell {
    grid-template-columns: 0.92fr 1.08fr;
  }

  .process-cards {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .step-index {
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #fff7e6;
    border: 1px solid rgba(255, 182, 55, 0.35);
    color: #8a6513;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .cta-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: linear-gradient(120deg, #1f1f1f 0%, #2b2b2b 100%);
    color: white;
  }

  .cta-banner p,
  .cta-banner h2 {
    color: white;
  }

  .cta-banner .button-secondary {
    color: white;
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.08);
  }

  .cta-banner .eyebrow {
    color: #8a6513;
    background: rgba(255, 182, 55, 0.18);
  }

  .cta-actions {
    margin: 0;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .split-section,
    .process-shell,
    .trust-band,
    .highlight-grid,
    .contact-mini-grid,
    .process-cards,
    .trust-points,
    .service-links-grid,
    .cta-banner {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
