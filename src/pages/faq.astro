---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const faq = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.data.question,
    acceptedAnswer: { '@type': 'Answer', text: item.data.answer },
  })),
};
const openingPoints = [
  'מתי נכון לפנות ולקבל ייעוץ',
  'מה אפשר להסדיר בהסכם ומה דורש טיפול אחר',
  'איך להבין את המצב בלי להילחץ מכל צעד',
];
---
<BaseLayout title="שאלות נפוצות | עו״ד אליזבט ברזאני דדון">
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <PageHero eyebrow="שאלות נפוצות" title="מענה ברור לשאלות שעולות בתחילת הדרך" description="כאן אפשר למצוא תשובות ראשוניות לשאלות נפוצות שעולות בתחילת הדרך." />

  <section class="section faq-intro-section">
    <div class="container faq-intro-grid">
      <div class="card faq-intro-card">
        <div class="eyebrow">מה חשוב לדעת</div>
        <h2>שאלות שעוזרות לעשות קצת סדר בתוך תקופה שמרגישה לא פעם עמוסה ומבלבלת</h2>
        <ul class="opening-points">
          {openingPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>
      <div class="card faq-intro-side">
        <div class="eyebrow">חשוב לדעת</div>
        <p>התשובות כאן נותנות כיוון ראשוני, אבל כל מקרה נבחן לפי הנסיבות שלו. לפעמים שינוי קטן בפרטים משנה את התמונה כולה.</p>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container faq-list">
      {faq.map((item) => (
        <details class="card faq-item">
          <summary>{item.data.question}</summary>
          <p>{item.data.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="section section-alt">
    <div class="container faq-cta card">
      <div>
        <div class="eyebrow">עדיין יש שאלה?</div>
        <h2>אם משהו נשאר לא ברור, אפשר לפנות ולקבל כיוון ראשוני בשיחה רגועה ומסודרת</h2>
        <p>לא צריך לדעת להגדיר בדיוק את הבעיה מראש. אפשר פשוט לתאר את המצב, ואני אעזור להבין מה נכון לבדוק ואיך נכון להתקדם.</p>
      </div>
      <a class="button button-primary" href={withBase('/contact')}>לתיאום שיחת ייעוץ</a>
    </div>
  </section>
</BaseLayout>

<style>
  .faq-intro-grid,
  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-intro-grid {
    grid-template-columns: 1.05fr 0.95fr;
    align-items: start;
  }

  .faq-intro-card {
    background: linear-gradient(180deg, var(--color-card-strong) 0%, var(--color-surface-warm) 100%);
  }

  .faq-intro-side {
    background: linear-gradient(180deg, var(--color-card) 0%, var(--color-surface-warm) 100%);
  }

  .opening-points {
    margin: 0;
    padding-right: 1.2rem;
    display: grid;
    gap: 0.8rem;
    color: var(--color-soft-text);
  }

  .faq-section {
    padding-top: 1.5rem;
  }

  .faq-list {
    max-width: 920px;
  }

  .faq-item {
    padding: 1.25rem 1.35rem;
    background: var(--color-card);
  }

  .faq-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-strong);
    border-color: rgba(201, 162, 75, 0.28);
  }

  summary {
    cursor: pointer;
    font-weight: 700;
    list-style: none;
    position: relative;
    padding-left: 2rem;
    line-height: 1.65;
  }

  summary::before {
    content: '+';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-primary-deep);
    font-size: 1.3rem;
    line-height: 1;
  }

  details[open] summary::before {
    content: '–';
  }

  details[open] summary {
    margin-bottom: 0.8rem;
  }

  .faq-item p {
    color: var(--color-soft-text);
    line-height: 1.9;
    margin-bottom: 0;
  }

  .faq-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: linear-gradient(135deg, var(--color-surface-warm) 0%, var(--color-card-strong) 100%);
  }

  @media (max-width: 900px) {
    .faq-intro-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .faq-cta {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }

    .faq-item {
      padding: 1rem 1.05rem;
    }
  }
</style>
