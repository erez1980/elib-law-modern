---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../data/site';
import aboutPage from '../data/about-page.json';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const heroImage = withBase(site.heroImage);
---
<BaseLayout title="אודות | עו״ד אליזבט ברזאני דדון">
  <section class="section about-hero">
    <div class="container about-grid">
      <div class="about-copy card">
        <SectionHeading eyebrow="אודות" title={aboutPage.title} description={aboutPage.description} />
        {aboutPage.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="card image-card">
        <img src={heroImage} alt={site.shortName} />
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container values-shell">
      <SectionHeading eyebrow="הגישה המקצועית" title="שלושה עקרונות שמובילים את העבודה במשרד" />
      <div class="values-grid">
        {aboutPage.values.map((value) => (
          <article class="card value-card">
            <h3>{value.title}</h3>
            <p>{value.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid,
  .values-grid {
    display: grid;
    gap: 2rem;
  }

  .about-grid {
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
  }

  .about-copy {
    background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
  }

  .image-card img {
    border-radius: 22px;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .values-shell {
    display: grid;
    gap: 1.5rem;
  }

  .values-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .value-card {
    min-height: 100%;
  }

  @media (max-width: 900px) {
    .about-grid,
    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
