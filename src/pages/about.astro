---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../data/site';
import aboutPage from '../data/about-page.json';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const heroImage = withBase(site.heroImage);
const workStyle = [
  'להתחיל מסדר ובהירות, לא מלחץ ומהירות',
  'להסתכל גם על ההשלכות האנושיות, לא רק על הסעיף המשפטי',
  'לשמור על דיסקרטיות, כבוד ותקשורת עניינית',
  'לבחור בכל פעם את הדרך שתשרת את הלקוח בצורה הנכונה ביותר',
];
---
<BaseLayout title="אודות | עו״ד אליזבט ברזאני דדון">
  <section class="section about-hero">
    <div class="container about-grid">
      <div class="about-copy card">
        <SectionHeading eyebrow="אודות" title={aboutPage.title} description={aboutPage.description} />
        {aboutPage.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="card image-card">
        <img src={heroImage} alt={site.shortName} />
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container values-shell">
      <SectionHeading eyebrow="הגישה המקצועית" title="כך נראה ליווי משפטי שנשען גם על מקצועיות וגם על שיקול דעת" />
      <div class="values-grid">
        {aboutPage.values.map((value) => (
          <article class="card value-card">
            <h3>{value.title}</h3>
            <p>{value.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container authority-grid">
      <article class="card authority-card authority-card--main">
        <div class="eyebrow">מה חשוב בעבודה</div>
        <h2>לא רק לפתור את הבעיה המשפטית, אלא גם לעזור לעבור את התקופה הזאת בצורה נכונה יותר</h2>
        <ul class="work-style-list">
          {workStyle.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card authority-card authority-card--side">
        <div class="eyebrow">למה לבחור במשרד</div>
        <p>שילוב בין ניסיון מקצועי, גישור וייצוג משפטי, טיפול אישי וישיר, וחשיבה שמחפשת את הדרך הנכונה לכל מקרה - לא את הדרך האוטומטית.</p>
        <div class="mini-divider"></div>
        <div class="eyebrow">אזורי שירות</div>
        <p>המשרד מלווה לקוחות מקדימה צורן, אזור השרון ומקומות נוספים בארץ, בפגישות מסודרות וליווי אישי לאורך הדרך.</p>
      </article>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container about-cta card">
      <div>
        <div class="eyebrow">פנייה ראשונה</div>
        <h2>אם חשוב לך להבין מול מי עובדים ואיך נראה הליווי, אפשר להתחיל בשיחה רגועה וברורה</h2>
        <p>לפעמים שיחה אחת מסודרת כבר עושה הרבה סדר. אפשר לפנות, לשאול, להבין את האפשרויות, ולקבל כיוון ראשוני בלי לחץ מיותר.</p>
      </div>
      <a class="button button-primary" href={withBase('/contact')}>לתיאום שיחת ייעוץ</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid,
  .values-grid,
  .authority-grid {
    display: grid;
    gap: 2rem;
  }

  .about-grid {
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
  }

  .about-copy {
    background: linear-gradient(180deg, var(--color-card-strong) 0%, var(--color-surface-warm) 100%);
  }

  .image-card img {
    border-radius: 22px;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .values-shell {
    display: grid;
    gap: 1.5rem;
  }

  .values-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .authority-grid {
    grid-template-columns: 1.1fr 0.9fr;
    align-items: start;
  }

  .value-card,
  .authority-card,
  .about-cta {
    min-height: 100%;
  }

  .value-card {
    background: linear-gradient(180deg, var(--color-card) 0%, var(--color-surface-warm) 100%);
  }

  .authority-card--main {
    background: linear-gradient(180deg, var(--color-card-strong) 0%, var(--color-surface-warm) 100%);
  }

  .authority-card--side {
    background: linear-gradient(180deg, var(--color-card) 0%, var(--color-surface-warm) 100%);
  }

  .work-style-list {
    margin: 0;
    padding-right: 1.2rem;
    display: grid;
    gap: 0.8rem;
    color: var(--color-soft-text);
  }

  .mini-divider {
    width: 72px;
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary), transparent);
    margin: 1.15rem 0;
  }

  .about-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: linear-gradient(135deg, var(--color-surface-warm) 0%, var(--color-card-strong) 100%);
  }

  @media (max-width: 900px) {
    .about-grid,
    .values-grid,
    .authority-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .values-shell {
      gap: 1rem;
    }

    .image-card img {
      aspect-ratio: 16 / 12;
    }

    .about-cta {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }
  }
</style>
