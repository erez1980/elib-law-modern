---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const articles = (await getCollection('articles')).filter((item) => !item.data.draft);
---
<BaseLayout title="מאמרים | עו״ד אליזבט ברזאני דדון">
  <section class="section">
    <div class="container">
      <SectionHeading eyebrow="מאמרים" title="בסיס מוכן למאמרים עתידיים, כולל תוכן מבוסס AI" description="האזור הזה יאפשר להעלות מאמרים איכותיים, ללטש אותם עם AI, ולנהל אותם בקלות דרך ה‑CMS." />
      <div class="articles-grid">
        {articles.map((article) => (
          <article class="card">
            <p>{article.data.publishDate}</p>
            <h2><a href={withBase(`/articles/${article.id.replace(/\.md$/, '')}`)}>{article.data.title}</a></h2>
            <p>{article.data.excerpt}</p>
            <a class="text-link" href={withBase(`/articles/${article.id.replace(/\.md$/, '')}`)}>לקריאת המאמר</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .articles-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .text-link {
    color: #8a6513;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
