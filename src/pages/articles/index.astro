---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const articles = (await getCollection('articles'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.publishDate.localeCompare(a.data.publishDate));
---
<BaseLayout title="מאמרים בדיני משפחה | עו״ד אליזבט ברזאני דדון">
  <PageHero eyebrow="מאמרים" title="מאמרים מקצועיים בדיני משפחה, גישור, צוואות וייפוי כוח מתמשך" description="ריכזנו כאן מידע שימושי וברור בנושאים משפטיים שמעסיקים משפחות, זוגות ויחידים לפני קבלת החלטות משמעותיות." />

  <section class="section articles-section">
    <div class="container articles-grid">
      {articles.map((article) => (
        <a class="card article-card" href={withBase(`/articles/${article.id.replace(/\.md$/, '')}`)}>
          <p class="article-date">{article.data.publishDate}</p>
          <h2>{article.data.title}</h2>
          <p>{article.data.excerpt}</p>
          <span class="text-link">לקריאת המאמר</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .articles-section {
    padding-top: 1.5rem;
  }

  .articles-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .article-card {
    min-height: 100%;
    display: grid;
    gap: 0.8rem;
    transition: 180ms ease;
    align-content: start;
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-strong);
  }

  .article-date {
    color: var(--color-primary-deep);
    font-weight: 700;
    margin-bottom: 0;
    font-size: 0.95rem;
  }

  .article-card p {
    color: #5c5c5c;
    line-height: 1.9;
  }

  .text-link {
    color: #8a6513;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
