---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const articles = (await getCollection('articles')).filter((item) => !item.data.draft);
---
<BaseLayout title="מאמרים | עו״ד אליזבט ברזאני דדון">
  <PageHero eyebrow="מאמרים" title="בסיס לתוכן מקצועי איכותי, בהיר ואמין" description="האזור הזה נבנה כמגזין מקצועי קטן: קריא יותר, אלגנטי יותר, ומוכן להתרחבות עתידית עם תוכן מבוסס AI." />

  <section class="section articles-section">
    <div class="container articles-grid">
      {articles.map((article) => (
        <article class="card article-card">
          <p class="article-date">{article.data.publishDate}</p>
          <h2><a href={withBase(`/articles/${article.id.replace(/\.md$/, '')}`)}>{article.data.title}</a></h2>
          <p>{article.data.excerpt}</p>
          <a class="text-link" href={withBase(`/articles/${article.id.replace(/\.md$/, '')}`)}>לקריאת המאמר</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .articles-section {
    padding-top: 1.5rem;
  }

  .articles-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .article-card {
    min-height: 100%;
    display: grid;
    gap: 0.8rem;
  }

  .article-date {
    color: var(--color-primary-deep);
    font-weight: 700;
    margin-bottom: 0;
  }

  .text-link {
    color: #8a6513;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
