---
import FloatingActions from '../components/FloatingActions.astro';
import { site, navigation } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const { title = site.title, description = site.description, image = site.heroImage, noIndex = false } = Astro.props;
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const homeHref = withBase('/');
const contactHref = withBase('/contact');
const logoHref = withBase(site.logo);
const ogImage = new URL(withBase(image), Astro.site ?? Astro.url).toString();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ''), '') || '/';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: site.name,
  description,
  url: canonicalUrl,
  image: ogImage,
  telephone: site.phone,
  email: site.email,
  areaServed: ['קדימה צורן', 'אזור השרון', 'ישראל'],
  sameAs: site.facebook ? [site.facebook] : [],
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address,
    addressCountry: 'IL',
  },
};
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FFB637" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700;800&family=Assistant:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href={logoHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="he_IL" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={homeHref} class="brand">
          <img src={logoHref} alt={site.shortName} class="brand-logo" />
          <div>
            <strong>{site.shortName}</strong>
            <span>{site.tagline}</span>
          </div>
        </a>
        <nav class="nav" aria-label="ניווט ראשי">
          {navigation.map((item) => {
            const href = withBase(item.href);
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return <a href={href} aria-current={isActive ? 'page' : undefined} class={isActive ? 'active' : ''}>{item.label}</a>;
          })}
        </nav>
        <a href={contactHref} class="button button-primary">לתיאום שיחת ייעוץ</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <FloatingActions />
    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand-col">
          <h3>{site.shortName}</h3>
          <p>{site.description}</p>
          <p class="footer-note">ליווי אישי, דיסקרטי ושקול בדיני משפחה, גישור, צוואות, ירושות וייפוי כוח מתמשך.</p>
        </div>
        <div>
          <h4>ניווט מהיר</h4>
          <ul>
            {navigation.map((item) => <li><a href={withBase(item.href)}>{item.label}</a></li>)}
          </ul>
        </div>
        <div>
          <h4>יצירת קשר</h4>
          <ul>
            <li><a href={`tel:${site.phone.replace(/-/g, '')}`}>{site.phone}</a></li>
            <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
            <li>{site.address}</li>
            <li>{site.hours[0]}</li>
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #ffb637;
    --color-primary-deep: #b88420;
    --color-text: #2d2d2d;
    --color-muted: #666666;
    --color-surface: #f7f7f7;
    --color-surface-warm: #fffaf1;
    --color-border: #e6e6e6;
    --color-white: #ffffff;
    --shadow-soft: 0 18px 50px rgba(45, 45, 45, 0.08);
    --shadow-strong: 0 30px 80px rgba(45, 45, 45, 0.14);
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 12px;
    --container: min(1120px, calc(100vw - 2rem));
  }

  html {
    font-family: 'Assistant', 'Heebo', Arial, sans-serif;
    color: var(--color-text);
    background: var(--color-white);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    line-height: 1.8;
    font-size: 1.04rem;
    background:
      radial-gradient(circle at top right, rgba(255, 182, 55, 0.08), transparent 24%),
      linear-gradient(180deg, #fffdf9 0%, #ffffff 22%);
  }

  * {
    box-sizing: border-box;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .container {
    width: var(--container);
    margin-inline: auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.88);
    border-bottom: 1px solid rgba(230, 230, 230, 0.78);
    backdrop-filter: blur(18px);
    box-shadow: 0 8px 30px rgba(45, 45, 45, 0.04);
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.25rem;
    min-height: 84px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    font-size: 0.95rem;
  }

  .brand strong {
    display: block;
    font-size: 1rem;
    font-family: 'Heebo', 'Assistant', Arial, sans-serif;
  }

  .brand span {
    color: var(--color-muted);
    font-size: 0.88rem;
  }

  .brand-logo {
    width: 54px;
    height: 54px;
    object-fit: contain;
    border-radius: 14px;
    background: #fff9ec;
    padding: 0.55rem;
    border: 1px solid rgba(255, 182, 55, 0.35);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav a {
    color: var(--color-muted);
    font-weight: 500;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    transition: 180ms ease;
  }

  .nav a:hover,
  .nav a.active {
    color: var(--color-text);
    background: rgba(255, 182, 55, 0.14);
    box-shadow: inset 0 0 0 1px rgba(255, 182, 55, 0.16);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1.3rem;
    border-radius: 999px;
    font-weight: 700;
    transition: 180ms ease;
    border: 1px solid transparent;
  }

  .button-primary {
    background: linear-gradient(135deg, #ffcf73 0%, var(--color-primary) 100%);
    color: var(--color-text);
    box-shadow: var(--shadow-soft);
  }

  .button-secondary {
    background: transparent;
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .button:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-strong);
  }

  .section {
    padding: 5rem 0;
  }

  .section-alt {
    background: var(--color-surface);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: #8a6513;
    background: #fff7e6;
    border: 1px solid rgba(255, 182, 55, 0.35);
    border-radius: 999px;
    padding: 0.45rem 0.85rem;
    margin-bottom: 1rem;
  }

  h1, h2, h3, h4 {
    line-height: 1.22;
    margin: 0 0 1rem;
    font-family: 'Heebo', 'Assistant', Arial, sans-serif;
    letter-spacing: -0.01em;
  }

  h1 {
    font-size: clamp(2rem, 3.1vw, 3.4rem);
  }

  h2 {
    font-size: clamp(1.55rem, 2.3vw, 2.35rem);
  }

  h3 {
    font-size: clamp(1.2rem, 1.6vw, 1.5rem);
  }

  p {
    margin: 0 0 1rem;
    color: #575757;
    max-width: 68ch;
  }

  .grid {
    display: grid;
    gap: 1.5rem;
  }

  .card {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(230, 230, 230, 0.92);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(8px);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .site-footer {
    padding: 3rem 0 7rem;
    background: linear-gradient(180deg, #252525 0%, #1b1b1b 100%);
    color: rgba(255, 255, 255, 0.88);
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .site-footer p,
  .site-footer li,
  .site-footer a {
    color: rgba(255, 255, 255, 0.76);
  }

  .footer-note {
    max-width: 42ch;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 900px) {
    .header-inner {
      min-height: auto;
      padding: 1rem 0;
      grid-template-columns: 1fr;
      align-items: stretch;
    }

    .nav {
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 0.25rem;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x proximity;
    }

    .nav a {
      scroll-snap-align: start;
      white-space: nowrap;
    }

    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
