---
import { Image } from 'astro:assets';
import FloatingActions from '../components/FloatingActions.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import Icon from '../components/Icon.astro';
import { site, navigation } from '../data/site';
import logoLight from '../assets/images/logo-light.png';
import logoDark from '../assets/images/logo-dark.jpg';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const { title = site.title, description = site.description, image = site.ogImage ?? site.heroImage, noIndex = false } = Astro.props;
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const homeHref = withBase('/');
const faviconPngHref = withBase('/favicon.png');
const faviconIcoHref = withBase('/favicon.ico');
const faviconSvgHref = withBase('/favicon.svg');
const appleTouchIconHref = withBase('/apple-touch-icon.png');
const ogImage = new URL(withBase(image), Astro.site ?? Astro.url).toString();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ''), '') || '/';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: site.name,
  description,
  url: canonicalUrl,
  image: ogImage,
  telephone: site.phone,
  email: site.email,
  areaServed: ['קדימה צורן', 'אזור השרון', 'ישראל'],
  sameAs: site.facebook ? [site.facebook] : [],
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address,
    addressCountry: 'IL',
  },
};
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#c9a24b" />
    <meta name="color-scheme" content="light dark" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700;800&family=Assistant:wght@400;500;600;700&family=Frank+Ruhl+Libre:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href={faviconSvgHref} />
    <link rel="icon" type="image/png" sizes="512x512" href={faviconPngHref} />
    <link rel="icon" href={faviconIcoHref} sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIconHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="he_IL" />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      (() => {
        const key = 'elib-theme';
        const root = document.documentElement;
        const saved = localStorage.getItem(key);
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (systemDark ? 'dark' : 'light');
        root.dataset.theme = theme;
      })();
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RD52L2GWWH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RD52L2GWWH');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={homeHref} class="brand">
          <Image src={logoLight} alt={site.shortName} width={160} format="webp" quality={82} class="brand-logo brand-logo--light" />
          <Image src={logoDark} alt={site.shortName} width={160} format="webp" quality={82} class="brand-logo brand-logo--dark" />
          <div class="brand-text">
            <strong>{site.shortName}</strong>
            <span>{site.tagline}</span>
          </div>
        </a>
        <nav class="nav" aria-label="ניווט ראשי">
          {navigation.map((item) => {
            const href = withBase(item.href);
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return <a href={href} aria-current={isActive ? 'page' : undefined} class={isActive ? 'active' : ''}>{item.label}</a>;
          })}
        </nav>
        <div class="header-actions">
          <details class="mobile-menu">
            <summary aria-label="פתיחת תפריט"><Icon name="menu" size={20} /></summary>
            <nav class="mobile-menu-panel" aria-label="ניווט מובייל">
              {navigation.map((item) => {
                const href = withBase(item.href);
                const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
                return <a href={href} aria-current={isActive ? 'page' : undefined} class={isActive ? 'active' : ''}>{item.label}</a>;
              })}
            </nav>
          </details>
          <button class="theme-toggle" type="button" aria-label="שינוי מצב תצוגה" title="שינוי מצב תצוגה">
            <Icon name="sun" size={20} class="theme-toggle-icon theme-toggle-sun" />
            <Icon name="moon" size={20} class="theme-toggle-icon theme-toggle-moon" />
          </button>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <FloatingActions />
    <AccessibilityWidget />
    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand-col">
          <h3>{site.shortName}</h3>
          <p>{site.description}</p>
        </div>
        <div>
          <h4>ניווט מהיר</h4>
          <ul>
            {navigation.map((item) => <li><a href={withBase(item.href)}>{item.label}</a></li>)}
          </ul>
        </div>
        <div>
          <h4>יצירת קשר</h4>
          <ul>
            <li><a href={`tel:${site.phone.replace(/-/g, '')}`}>{site.phone}</a></li>
            <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
            <li>{site.address}</li>
            <li>{site.hours[0]}</li>
          </ul>
        </div>
      </div>
      <div class="container footer-legal">
        <a href={withBase('/accessibility-statement')}>הצהרת נגישות</a>
        <span aria-hidden="true">·</span>
        <a href={withBase('/privacy')}>מדיניות פרטיות</a>
        <span aria-hidden="true">·</span>
        <span>© {new Date().getFullYear()} {site.shortName}. התוכן באתר הוא מידע כללי ואינו מהווה ייעוץ משפטי.</span>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const key = 'elib-theme';
        const root = document.documentElement;
        const toggle = document.querySelector('.theme-toggle');
        const applyTheme = (theme) => {
          root.dataset.theme = theme;
          localStorage.setItem(key, theme);
          toggle?.setAttribute('aria-pressed', String(theme === 'dark'));
        };
        if (toggle) {
          toggle.addEventListener('click', () => {
            const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            applyTheme(next);
          });
          toggle.setAttribute('aria-pressed', String(root.dataset.theme === 'dark'));
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #c9a24b;
    --color-primary-deep: #8f7130;
    --color-text: #2d2d2d;
    --color-muted: #666666;
    --color-surface: #f7f7f7;
    --color-surface-warm: #fffaf1;
    --color-border: #e6e6e6;
    --color-white: #ffffff;
    --color-page-top: #fffdf9;
    --color-header: rgba(255, 255, 255, 0.88);
    --color-header-border: rgba(230, 230, 230, 0.78);
    --color-card: rgba(255, 255, 255, 0.92);
    --color-card-strong: rgba(255,255,255,0.97);
    --color-overlay: rgba(31, 31, 31, 0.78);
    --color-overlay-text: rgba(255, 255, 255, 0.82);
    --color-pill-bg: #fff7e6;
    --color-pill-text: #7a5f24;
    --color-soft-text: #575757;
    --color-footer-bg-start: #252525;
    --color-footer-bg-end: #1b1b1b;
    --shadow-soft: 0 18px 50px rgba(45, 45, 45, 0.08);
    --shadow-strong: 0 30px 80px rgba(45, 45, 45, 0.14);
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 12px;
    --container: min(1120px, calc(100vw - 2rem));
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-primary: #e5b34a;
      --color-primary-deep: #e8c87e;
      --color-text: #f3efe7;
      --color-muted: #c0b8ab;
      --color-surface: #121212;
      --color-surface-warm: #171514;
      --color-border: rgba(255, 255, 255, 0.08);
      --color-white: #0f0f10;
      --color-page-top: #151312;
      --color-header: rgba(16, 16, 17, 0.82);
      --color-header-border: rgba(255, 255, 255, 0.06);
      --color-card: rgba(24, 24, 26, 0.92);
      --color-card-strong: rgba(29, 29, 31, 0.96);
      --color-overlay: rgba(10, 10, 11, 0.82);
      --color-overlay-text: rgba(255, 255, 255, 0.86);
      --color-pill-bg: rgba(242, 184, 75, 0.12);
      --color-pill-text: #e6c67c;
      --color-soft-text: #ddd5ca;
      --color-footer-bg-start: #0f0f10;
      --color-footer-bg-end: #0a0a0b;
      --shadow-soft: 0 18px 50px rgba(0, 0, 0, 0.32);
      --shadow-strong: 0 30px 80px rgba(0, 0, 0, 0.45);
    }
  }

  :root[data-theme='dark'] {
    --color-primary: #e5b34a;
    --color-primary-deep: #e8c87e;
    --color-text: #f3efe7;
    --color-muted: #c0b8ab;
    --color-surface: #121212;
    --color-surface-warm: #171514;
    --color-border: rgba(255, 255, 255, 0.08);
    --color-white: #0f0f10;
    --color-page-top: #151312;
    --color-header: rgba(16, 16, 17, 0.82);
    --color-header-border: rgba(255, 255, 255, 0.06);
    --color-card: rgba(24, 24, 26, 0.92);
    --color-card-strong: rgba(29, 29, 31, 0.96);
    --color-overlay: rgba(10, 10, 11, 0.82);
    --color-overlay-text: rgba(255, 255, 255, 0.86);
    --color-pill-bg: rgba(242, 184, 75, 0.12);
    --color-pill-text: #e6c67c;
    --color-soft-text: #ddd5ca;
    --color-footer-bg-start: #0f0f10;
    --color-footer-bg-end: #0a0a0b;
    --shadow-soft: 0 18px 50px rgba(0, 0, 0, 0.32);
    --shadow-strong: 0 30px 80px rgba(0, 0, 0, 0.45);
  }

  :root[data-theme='light'] {
    --color-primary: #c9a24b;
    --color-primary-deep: #8f7130;
    --color-text: #2d2d2d;
    --color-muted: #666666;
    --color-surface: #f7f7f7;
    --color-surface-warm: #fffaf1;
    --color-border: #e6e6e6;
    --color-white: #ffffff;
    --color-page-top: #fffdf9;
    --color-header: rgba(255, 255, 255, 0.88);
    --color-header-border: rgba(230, 230, 230, 0.78);
    --color-card: rgba(255, 255, 255, 0.92);
    --color-card-strong: rgba(255,255,255,0.97);
    --color-overlay: rgba(31, 31, 31, 0.78);
    --color-overlay-text: rgba(255, 255, 255, 0.82);
    --color-pill-bg: #fff7e6;
    --color-pill-text: #7a5f24;
    --color-soft-text: #575757;
    --color-footer-bg-start: #252525;
    --color-footer-bg-end: #1b1b1b;
    --shadow-soft: 0 18px 50px rgba(45, 45, 45, 0.08);
    --shadow-strong: 0 30px 80px rgba(45, 45, 45, 0.14);
  }

  html {
    font-family: 'Assistant', 'Heebo', Arial, sans-serif;
    color: var(--color-text);
    background: var(--color-white);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    line-height: 1.8;
    font-size: 1.04rem;
    background:
      radial-gradient(circle at top right, rgba(201, 162, 75, 0.08), transparent 24%),
      linear-gradient(180deg, var(--color-page-top) 0%, var(--color-white) 22%);
  }

  * {
    box-sizing: border-box;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .container {
    width: var(--container);
    margin-inline: auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--color-header);
    border-bottom: 1px solid var(--color-header-border);
    backdrop-filter: blur(18px);
    box-shadow: 0 8px 30px rgba(45, 45, 45, 0.04);
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.25rem;
    min-height: 84px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .theme-toggle {
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    color: var(--color-text);
    display: inline-grid;
    place-items: center;
    cursor: pointer;
    position: relative;
    box-shadow: var(--shadow-soft);
  }

  .theme-toggle:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-strong);
  }

  .theme-toggle-icon {
    position: absolute;
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .theme-toggle-sun {
    opacity: 1;
    transform: scale(1);
  }

  .theme-toggle-moon {
    opacity: 0;
    transform: scale(0.7);
  }

  :root[data-theme='dark'] .theme-toggle-sun {
    opacity: 0;
    transform: scale(0.7);
  }

  :root[data-theme='dark'] .theme-toggle-moon {
    opacity: 1;
    transform: scale(1);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    font-size: 0.95rem;
  }

  .brand strong {
    display: block;
    font-size: 1rem;
    font-family: 'Heebo', 'Assistant', Arial, sans-serif;
  }

  .brand span {
    color: var(--color-muted);
    font-size: 0.88rem;
  }

  .brand-logo {
    width: 78px;
    height: 78px;
    object-fit: contain;
    border-radius: 14px;
    background: transparent;
    padding: 0;
    border: 0;
    box-shadow: none;
    flex: 0 0 auto;
  }

  .brand-logo--dark {
    display: none;
  }

  :root[data-theme='dark'] .brand-logo--light {
    display: none;
  }

  :root[data-theme='dark'] .brand-logo--dark {
    display: block;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .mobile-menu {
    display: none;
    position: relative;
  }

  .mobile-menu summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    color: var(--color-text);
    font-weight: 800;
    box-shadow: var(--shadow-soft);
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu-panel {
    margin-top: 0.5rem;
    padding: 0.75rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-card-strong);
    box-shadow: var(--shadow-soft);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    width: min(320px, calc(100vw - 2rem));
    z-index: 30;
  }

  .mobile-menu-panel a {
    padding: 0.75rem;
    border-radius: 14px;
    background: var(--color-surface-warm);
    color: var(--color-text);
    font-weight: 700;
    text-align: center;
  }

  .mobile-menu-panel a.active {
    background: var(--color-pill-bg);
    color: var(--color-pill-text);
  }

  .nav a {
    color: var(--color-muted);
    font-weight: 500;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    transition: 180ms ease;
  }

  .nav a:hover,
  .nav a.active {
    color: var(--color-text);
    background: rgba(201, 162, 75, 0.14);
    box-shadow: inset 0 0 0 1px rgba(201, 162, 75, 0.16);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1.3rem;
    border-radius: 999px;
    font-weight: 700;
    transition: 180ms ease;
    border: 1px solid transparent;
  }

  .button-primary {
    background: linear-gradient(135deg, #e0c17a 0%, var(--color-primary) 100%);
    color: var(--color-text);
    box-shadow: var(--shadow-soft);
  }

  .button-secondary {
    background: transparent;
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .button:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-strong);
  }

  .section {
    padding: 5.75rem 0;
  }

  .section-alt {
    background: var(--color-surface);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-pill-text);
    background: var(--color-pill-bg);
    border: 1px solid rgba(201, 162, 75, 0.35);
    border-radius: 999px;
    padding: 0.45rem 0.85rem;
    margin-bottom: 1rem;
  }

  h1, h2, h3, h4 {
    line-height: 1.24;
    margin: 0 0 1rem;
    font-family: 'Frank Ruhl Libre', 'Heebo', 'Assistant', Georgia, serif;
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(2rem, 3.1vw, 3.4rem);
  }

  h2 {
    font-size: clamp(1.55rem, 2.3vw, 2.35rem);
  }

  h3 {
    font-size: clamp(1.2rem, 1.6vw, 1.5rem);
  }

  p {
    margin: 0 0 1rem;
    color: var(--color-soft-text);
    max-width: 68ch;
  }

  .grid {
    display: grid;
    gap: 1.5rem;
  }

  .card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(8px);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .site-footer {
    padding: 3rem 0 7rem;
    background: linear-gradient(180deg, var(--color-footer-bg-start) 0%, var(--color-footer-bg-end) 100%);
    color: rgba(255, 255, 255, 0.88);
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .site-footer p,
  .site-footer li,
  .site-footer a {
    color: rgba(255, 255, 255, 0.76);
  }

  .footer-note {
    max-width: 42ch;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-legal {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .footer-legal a {
    color: rgba(255, 255, 255, 0.72);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-legal a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    body {
      padding-bottom: 82px;
    }

    h1 {
      font-size: clamp(1.75rem, 8vw, 2.45rem);
    }

    h2 {
      font-size: clamp(1.35rem, 6vw, 1.95rem);
    }

    .section {
      padding: 3rem 0;
    }

    .card {
      padding: 1.15rem;
      border-radius: 18px;
    }

    .header-inner {
      min-height: auto;
      padding: 0.3rem 0;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.25rem;
    }

    .brand {
      justify-content: flex-start;
      text-align: right;
      min-width: 0;
      gap: 0.45rem;
      width: 100%;
      flex: 1 1 auto;
    }

    .brand-logo {
      width: 56px;
      height: 56px;
      border-radius: 9px;
      padding: 0;
      flex: 0 0 auto;
    }

    .brand-text {
      min-width: 0;
      width: 100%;
    }

    .brand strong {
      font-size: 0.88rem;
      margin-bottom: 0.1rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand span {
      font-size: 0.74rem;
      line-height: 1.25;
      display: block;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .header-actions {
      display: flex;
      justify-content: flex-end;
      gap: 0.22rem;
      align-items: center;
      flex: 0 0 auto;
    }

    .theme-toggle {
      width: 30px;
