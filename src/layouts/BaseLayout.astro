---
import { site, navigation } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path === '/' ? '/' : path}`;
const homeHref = withBase('/');
const contactHref = withBase('/contact');
const logoHref = withBase(site.logo);
const ogImage = new URL(withBase(site.heroImage), Astro.site ?? Astro.url).toString();
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FFB637" />
    <link rel="icon" type="image/png" href={logoHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString()} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={homeHref} class="brand">
          <img src={logoHref} alt={site.shortName} class="brand-logo" />
          <div>
            <strong>{site.shortName}</strong>
            <span>{site.tagline}</span>
          </div>
        </a>
        <nav class="nav" aria-label="ניווט ראשי">
          {navigation.map((item) => (
            <a href={withBase(item.href)}>{item.label}</a>
          ))}
        </nav>
        <a href={contactHref} class="button button-primary">לתיאום שיחת ייעוץ</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <h3>{site.shortName}</h3>
          <p>{site.description}</p>
        </div>
        <div>
          <h4>יצירת קשר</h4>
          <ul>
            <li><a href={`tel:${site.phone.replace(/-/g, '')}`}>{site.phone}</a></li>
            <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
            <li>{site.address}</li>
          </ul>
        </div>
        <div>
          <h4>שעות פעילות</h4>
          <ul>
            {site.hours.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #ffb637;
    --color-text: #2d2d2d;
    --color-muted: #666666;
    --color-surface: #f7f7f7;
    --color-border: #e6e6e6;
    --color-white: #ffffff;
    --shadow-soft: 0 18px 50px rgba(45, 45, 45, 0.08);
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 12px;
    --container: min(1120px, calc(100vw - 2rem));
  }

  html {
    font-family: 'Heebo', 'Assistant', Arial, sans-serif;
    color: var(--color-text);
    background: var(--color-white);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    line-height: 1.7;
  }

  * {
    box-sizing: border-box;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .container {
    width: var(--container);
    margin-inline: auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.92);
    border-bottom: 1px solid rgba(230, 230, 230, 0.9);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 84px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    font-size: 0.95rem;
  }

  .brand strong {
    display: block;
    font-size: 1rem;
  }

  .brand span {
    color: var(--color-muted);
    font-size: 0.88rem;
  }

  .brand-logo {
    width: 54px;
    height: 54px;
    object-fit: contain;
    border-radius: 14px;
    background: #fff9ec;
    padding: 0.55rem;
    border: 1px solid rgba(255, 182, 55, 0.35);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav a {
    color: var(--color-muted);
    font-weight: 500;
  }

  .nav a:hover {
    color: var(--color-text);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1.3rem;
    border-radius: 999px;
    font-weight: 700;
    transition: 180ms ease;
    border: 1px solid transparent;
  }

  .button-primary {
    background: var(--color-primary);
    color: var(--color-text);
    box-shadow: var(--shadow-soft);
  }

  .button-secondary {
    background: transparent;
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .section {
    padding: 5rem 0;
  }

  .section-alt {
    background: var(--color-surface);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: #8a6513;
    background: #fff7e6;
    border: 1px solid rgba(255, 182, 55, 0.35);
    border-radius: 999px;
    padding: 0.5rem 0.9rem;
    margin-bottom: 1rem;
  }

  h1, h2, h3, h4 {
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(2.2rem, 4vw, 4.5rem);
  }

  h2 {
    font-size: clamp(1.8rem, 3vw, 3rem);
  }

  p {
    margin: 0 0 1rem;
    color: var(--color-muted);
  }

  .grid {
    display: grid;
    gap: 1.5rem;
  }

  .card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    box-shadow: var(--shadow-soft);
  }

  .site-footer {
    padding: 3rem 0;
    background: #1f1f1f;
    color: rgba(255, 255, 255, 0.88);
  }

  .site-footer p,
  .site-footer li,
  .site-footer a {
    color: rgba(255, 255, 255, 0.76);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 900px) {
    .header-inner {
      min-height: auto;
      padding: 1rem 0;
      flex-direction: column;
      align-items: stretch;
    }

    .nav {
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 0.25rem;
    }

    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
